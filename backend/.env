# ─────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# ─────────────────────────────────────────────

# OTP Service (choose one)
# Option 1: Twilio (international)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Option 2: MSG91 (India - recommended)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=VRFYSM

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_MAX_RETRIES=3
OTP_RESEND_COOLDOWN_SECONDS=30

# App Settings
SECRET_KEY=your_super_secret_key_change_this_in_production
APP_ENV=development   # change to 'production' when deploying

# Database (SQLite used by default - no setup needed)
DATABASE_URL=sqlite:///./verification.db
